---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src="/assets/logo.svg" alt="Andrew Nasef" width="52" height="52" />
      <p>
        Andrew Nasef, Passionate solo freelancer, dedicated to turning ideas
        into reality. Let's collaborate on your project.
      </p>
    </div>

    <div class="footer-col">
      <h4>Sitemap</h4>
      <ul>
        {links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact us</h4>
      <ul>
        <li><a href="tel:+201004359533">Phone: (+20) 100 435 9533</a></li>
        <li><a href="mailto:andronasef@gmail.com">andronasef@gmail.com</a></li>
      </ul>
      <h4 class="social-head">Social</h4>
      <div class="socials">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} set:html={icons[s.icon]} />
        ))}
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>Andrew Nasef Copyright © <span id="copyYear">{new Date().getFullYear()}</span></p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: #141414 url('/assets/footer-bg.png') center / cover no-repeat;
    border-top: 1px solid var(--border);
    padding-top: clamp(3rem, 6vw, 4.5rem);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1.3fr;
    gap: clamp(2rem, 5vw, 4rem);
    padding-bottom: 3rem;
  }
  .footer-brand img {
    height: 52px;
    width: auto;
    margin-bottom: 1.25rem;
  }
  .footer-brand p {
    color: var(--muted);
    max-width: 34ch;
    margin: 0;
  }
  .footer-col h4 {
    font-size: 1.05rem;
    margin-bottom: 1.1rem;
  }
  .footer-col ul {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-col a {
    color: var(--muted);
    transition: color 0.2s var(--ease);
  }
  .footer-col a:hover {
    color: var(--accent);
  }
  .social-head {
    margin-top: 0;
  }
  .socials {
    display: flex;
    gap: 0.65rem;
  }
  .socials a {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--muted-2);
    transition: background 0.25s var(--ease), color 0.25s var(--ease),
      transform 0.25s var(--ease);
  }
  .socials a:hover {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }
  .socials :global(svg) {
    width: 18px;
    height: 18px;
  }
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-block: 1.5rem;
  }
  .footer-bottom p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    text-align: center;
  }
  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>

<script>
  // Keep the copyright year current client-side (build-time value is the
  // fallback). Runs on first load and after every ClientRouter navigation.
  function setYear() {
    const el = document.getElementById('copyYear');
    if (el) el.textContent = String(new Date().getFullYear());
  }
  document.addEventListener('astro:page-load', setYear);
</script>
