---
interface Props {
  title: string;
  img: string;
  type: string;
  tech?: string;
  href: string;
}
const { title, img, type, tech, href } = Astro.props;
const tags = [type, tech].filter(Boolean);
---

<article class="proj reveal">
  <a href={href} class="proj-media" aria-label={title}>
    <img src={img} alt={title} width="561" height="374" loading="lazy" />
  </a>
  <div class="proj-tags">
    {tags.map((t) => <span class="tag">{t}</span>)}
  </div>
  <h3><a href={href}>{title}</a></h3>
</article>

<style>
  .proj {
    display: flex;
    flex-direction: column;
  }
  .proj-media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius);
    aspect-ratio: 3 / 2;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .proj-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease);
  }
  .proj:hover .proj-media img {
    transform: scale(1.05);
  }
  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 0.6rem;
  }
  .tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--muted-2);
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 0.28rem 0.65rem;
    border-radius: 6px;
  }
  .proj h3 {
    font-size: 1.15rem;
    line-height: 1.3;
    margin: 0;
  }
  .proj h3 a {
    transition: color 0.2s var(--ease);
  }
  .proj:hover h3 a {
    color: var(--accent);
  }
</style>
