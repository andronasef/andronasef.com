---
import Base from "../layouts/Base.astro";
---

<Base
    title="Page Not Found — Andrew Nasef"
    description="The page you're looking for doesn't exist or has moved."
>
    <section class="nf">
        <div class="container nf-inner">
            <p class="nf-mark" data-hero aria-hidden="true">
                <span>4</span><span class="nf-hole">0</span><span>4</span>
            </p>

            <h1 data-hero>This page went missing.</h1>
            <p class="nf-lead" data-hero>
                The link may be broken, or the page may have moved. Let's get
                you back to something that exists.
            </p>

            <div class="nf-actions" data-hero>
                <a href="/" class="btn btn-primary">Back Home</a>
                <a href="/projects/" class="btn btn-ghost">
                    View Projects
                    <svg
                        viewBox="0 0 24 24"
                        width="16"
                        height="16"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><path d="M7 17 17 7"></path><path d="M7 7h10v10"
                        ></path></svg
                    >
                </a>
            </div>
        </div>

        <div class="nf-grid" aria-hidden="true"></div>
        <div class="nf-glow" aria-hidden="true"></div>
    </section>
</Base>

<style>
    .nf {
        position: relative;
        overflow: hidden;
        min-height: clamp(30rem, 78svh, 52rem);
        display: grid;
        place-items: center;
        text-align: center;
        padding-block: clamp(3rem, 8vw, 6rem);
    }
    .nf-inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .nf-mark {
        font-family: var(--display);
        font-weight: 700;
        font-size: clamp(5rem, 24vw, 13rem);
        line-height: 0.9;
        letter-spacing: -0.04em;
        color: var(--ink);
        margin: 0.5rem 0 1.5rem;
        display: flex;
    }
    /* The missing page, made literal: the middle 0 is a hole punched in the mark.
     Translucent accent is the fallback; the stroke sits on top where supported. */
    .nf-hole {
        color: rgba(26, 101, 252, 0.22);
        -webkit-text-stroke: clamp(2px, 0.7vw, 4px) var(--accent);
        animation: nf-flicker 6s var(--ease) infinite;
    }
    @keyframes nf-flicker {
        0%,
        44%,
        55%,
        100% {
            opacity: 1;
        }
        48% {
            opacity: 0.55;
        }
        51% {
            opacity: 0.8;
        }
    }

    .nf h1 {
        font-size: clamp(1.6rem, 4vw, 2.5rem);
        margin: 0 0 0.75rem;
    }
    .nf-lead {
        max-width: 44ch;
        color: var(--muted-2);
        font-size: clamp(1rem, 2.2vw, 1.15rem);
        margin: 0 0 2rem;
    }
    .nf-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        justify-content: center;
    }

    /* Blueprint grid + drifting blue glow — the homepage hero's backdrop, reused
     so a dead end still feels like part of the site. */
    .nf-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(720px, 92vw);
        height: 480px;
        background: radial-gradient(
            ellipse at center,
            rgba(26, 101, 252, 0.2),
            transparent 62%
        );
        filter: blur(24px);
        pointer-events: none;
        z-index: 0;
        animation: nf-drift 9s ease-in-out infinite alternate;
    }
    @keyframes nf-drift {
        from {
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.8;
        }
        to {
            transform: translate(-50%, -54%) scale(1.06);
            opacity: 1;
        }
    }
    .nf-grid {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
            linear-gradient(var(--border) 1px, transparent 1px),
            linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 56px 56px;
        opacity: 0.35;
        mask-image: radial-gradient(
            ellipse 70% 60% at 50% 50%,
            #000 20%,
            transparent 72%
        );
        -webkit-mask-image: radial-gradient(
            ellipse 70% 60% at 50% 50%,
            #000 20%,
            transparent 72%
        );
    }

    @media (prefers-reduced-motion: reduce) {
        .nf-glow,
        .nf-hole {
            animation: none;
        }
    }
</style>
