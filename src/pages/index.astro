---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects.js';

const featured = projects.slice(0, 6);

const services = [
  {
    title: 'Custom Website Development',
    desc: 'Tailor-made websites that combine design and functionality to suit your unique needs.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  },
  {
    title: 'Ecommerce Online Shops',
    desc: 'Powerful online shops built on WooCommerce, ensuring seamless transactions and user-friendly interfaces.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>',
  },
  {
    title: 'Branding Websites',
    desc: 'Showcase your brand identity with visually captivating websites that leave a lasting impression.',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="10.5" r="2.5"/><circle cx="8.5" cy="7.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><path d="M12 2a10 10 0 1 0 0 20 2.5 2.5 0 0 0 0-5 2.5 2.5 0 0 1-1.7-4.3"/></svg>',
  },
];

const stats = [
  { value: '+5', label: 'Happy Clients' },
  { value: '+10', label: 'Websites' },
  { value: '+15', label: 'Projects' },
];
---

<Base>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow reveal">Hello, my name is</span>
      <h1 class="reveal">Andrew<br />Nasef</h1>
      <p class="hero-lead reveal">
        I'm a Web Developer with +2 years experience, and I'm very passionate
        and <span class="accent">dedicated</span> to my work.
      </p>
      <div class="hero-social reveal" aria-label="Find me online">
        <a href="https://wa.me/201004359533" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.7-.9-2-1-.3-.1-.5-.2-.6.2-.2.3-.7.9-.9 1.1-.1.2-.3.2-.6.1-1.6-.8-2.6-1.4-3.7-3.2-.3-.5.3-.5.8-1.5.1-.2 0-.3 0-.5-.1-.2-.6-1.5-.9-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 1-1 2.4s1 2.8 1.2 3c.1.2 2 3.1 5 4.3 1.9.8 2.6.9 3.5.7.6-.1 1.7-.7 1.9-1.3.2-.7.2-1.2.2-1.3-.1-.2-.3-.2-.6-.4zM12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/andronasef" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.1c.5-.9 1.8-1.9 3.6-1.9 3.9 0 4.6 2.5 4.6 5.8V21h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2 1.4-2 2.8V21h-4V9z"/></svg>
        </a>
        <a href="https://github.com/andronasef/" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.7.3-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-4.9 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.6 0 0 .8-.3 2.7 1a9.4 9.4 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.3.2 2.3.1 2.6.6.7 1 1.6 1 2.7 0 3.8-2.4 4.6-4.6 4.9.3.3.6.9.6 1.9v2.8c0 .3.2.6.7.5A10 10 0 0 0 12 2z"/></svg>
        </a>
      </div>
      <div class="hero-actions reveal">
        <a href="/contact" class="btn btn-primary">Get a Free Quote</a>
        <a
          href="https://docs.google.com/document/d/e/2PACX-1vQEbKcSkb66LsypszQSt20vgQx5x6bfOzHrw0Ge1dDBwiQdXVonjbJj8ZZLguyBVvHEi9GyOW9oh3vX/pub"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener"
        >
          View My CV
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </a>
      </div>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Services</span>
        <h2>What I can do for you</h2>
      </div>
      <div class="services-grid">
        {services.map((s) => (
          <div class="service reveal">
            <div class="service-icon" set:html={s.icon} />
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container stats-grid">
      {stats.map((s) => (
        <div class="stat reveal">
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="projects">
    <div class="container">
      <div class="projects-head">
        <div class="reveal">
          <span class="eyebrow">Projects</span>
          <h2>Selected work</h2>
        </div>
        <a href="/projects" class="btn btn-ghost reveal">View all Projects</a>
      </div>
      <div class="project-grid">
        {featured.map((p) => <ProjectCard {...p} />)}
      </div>
      <div class="projects-foot reveal">
        <a href="/projects" class="btn btn-primary">View all Projects</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="container">
      <div class="section-head reveal">
        <span class="eyebrow">Testimonials</span>
        <h2>Happy Clients</h2>
        <p>
          Read testimonials from our satisfied clients and discover why they
          choose us for their web development needs.
        </p>
      </div>
      <figure class="quote reveal">
        <h3>Amazing Experience</h3>
        <blockquote>
          Andrew is one of the best programmers I have ever worked with. He is
          very knowledgeable in his field and a highly skilled programmer. In
          addition, he is very polite and respectful, and he is always open to
          feedback. I highly recommend working with him.
        </blockquote>
        <figcaption>
          <img src="/assets/avatar.webp" alt="Abo Mohamed" width="56" height="56" />
          <span>
            <strong>Abo Mohamed</strong>
            <em>Client</em>
          </span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- CONSULTATION CTA -->
  <section class="cta">
    <div class="container cta-inner">
      <div class="cta-copy reveal">
        <span class="eyebrow">Get a Free Consultation</span>
        <h2>Ready to build your dream project?</h2>
        <p>
          Ready to take the first step towards your dream project? Schedule a
          free consultation with me today and let's bring your vision to
          reality.
        </p>
        <a href="/contact" class="btn btn-primary">Let's Talk</a>
      </div>
      <div class="cta-art reveal">
        <img src="/assets/consultation.svg" alt="" width="420" height="420" loading="lazy" />
      </div>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    text-align: center;
    padding-block: clamp(3.5rem, 9vw, 7rem);
    overflow: hidden;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(3.5rem, 13vw, 6rem);
    letter-spacing: -0.04em;
    margin: 0.25rem 0 1.25rem;
  }
  .hero-lead {
    max-width: 46ch;
    color: var(--muted-2);
    font-size: clamp(1rem, 2.2vw, 1.15rem);
    margin: 0 0 1.75rem;
  }
  .hero-social {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .hero-social a {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted-2);
    transition: background 0.25s var(--ease), color 0.25s var(--ease),
      transform 0.25s var(--ease);
  }
  .hero-social a:hover {
    background: var(--accent);
    color: #fff;
    transform: translateY(-3px);
  }
  .hero-social svg {
    width: 20px;
    height: 20px;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    justify-content: center;
  }
  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: min(720px, 90vw);
    height: 480px;
    background: radial-gradient(
      ellipse at center,
      rgba(26, 101, 252, 0.18),
      transparent 62%
    );
    filter: blur(20px);
    pointer-events: none;
  }

  /* SERVICES */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .service {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .service:hover {
    transform: translateY(-4px);
    border-color: #3a3a3a;
  }
  .service-icon {
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 12px;
    background: rgba(26, 101, 252, 0.12);
    color: var(--accent);
    margin-bottom: 1.25rem;
  }
  .service-icon :global(svg) {
    width: 26px;
    height: 26px;
  }
  .service h3 {
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
  }
  .service p {
    color: var(--muted);
    margin: 0;
    font-size: 0.95rem;
  }

  /* STATS */
  .stats {
    padding-block: 0;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3rem);
  }
  .stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat-value {
    font-size: clamp(2.25rem, 6vw, 3.25rem);
    font-weight: 800;
    color: var(--ink);
    line-height: 1;
  }
  .stat-label {
    color: var(--muted);
    font-size: 0.95rem;
  }

  /* PROJECTS */
  .projects-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: clamp(1.75rem, 4vw, 2.5rem);
  }
  .projects-head h2 {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    margin: 0;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: clamp(1.5rem, 3vw, 2.25rem);
  }
  .projects-foot {
    display: flex;
    justify-content: center;
    margin-top: clamp(2.25rem, 5vw, 3.5rem);
  }

  /* TESTIMONIALS */
  .quote {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(2rem, 5vw, 3.25rem);
  }
  .quote h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }
  .quote blockquote {
    margin: 0 0 1.75rem;
    color: var(--muted-2);
    font-size: 1.05rem;
    line-height: 1.7;
  }
  .quote figcaption {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-align: left;
  }
  .quote figcaption img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  .quote figcaption strong {
    display: block;
    color: var(--ink);
  }
  .quote figcaption em {
    color: var(--muted);
    font-style: normal;
    font-size: 0.9rem;
  }

  /* CTA */
  .cta-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    background: linear-gradient(135deg, var(--surface), #191919);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: clamp(2rem, 5vw, 3.5rem);
  }
  .cta-copy h2 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }
  .cta-copy p {
    color: var(--muted);
    max-width: 46ch;
    margin: 0 0 1.75rem;
  }
  .cta-art {
    display: grid;
    place-items: center;
  }
  .cta-art img {
    width: min(100%, 380px);
    height: auto;
  }

  @media (max-width: 720px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .projects-head {
      flex-direction: column;
      align-items: flex-start;
    }
    .cta-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .cta-copy p {
      margin-inline: auto;
    }
    .cta-art {
      order: -1;
    }
  }
</style>
