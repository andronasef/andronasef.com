---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andrew Nasef — Web Developer',
  description = "I'm a Web Developer with +2 years experience, passionate and dedicated to my work.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg" />
    <link rel="preload" href="/fonts/ClashDisplay-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ClashDisplay-Semibold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ClashDisplay-Medium.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
    {import.meta.env.PROD && (
      <>
        {/* Google Analytics (GA4) */}
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-D08VV0R507"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          {/* Auto page_view off; fired manually on astro:page-load so SPA nav counts. */}
          gtag('config', 'G-D08VV0R507', { send_page_view: false });
        </script>

        {/* Microsoft Clarity */}
        <script is:inline>
          (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
          })(window, document, "clarity", "script", "xjilr51oo3");
        </script>
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppFloat transition:persist />

    <div class="page-transition" id="pageTransition" aria-hidden="true" transition:persist>
      <div class="pt-accent"></div>
      <div class="pt-dark">
        <img class="pt-logo" src="/assets/logo.svg" alt="" width="56" height="56" />
      </div>
    </div>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: var(--z-menu);
        background: var(--accent);
        color: #fff;
        padding: 0.75rem 1.25rem;
        border-radius: 0 0 8px 0;
      }
      .skip-link:focus {
        left: 0;
      }

      /* GSAP page-transition curtain. Panels park off-screen (below) until a
         navigation drives them via src/lib/motion.ts. */
      .page-transition {
        position: fixed;
        inset: 0;
        z-index: 500;
        pointer-events: none;
        overflow: hidden;
      }
      .pt-accent,
      .pt-dark {
        position: absolute;
        inset: 0;
        transform: translateY(100%);
        will-change: transform;
      }
      .pt-accent {
        background: var(--accent);
      }
      .pt-dark {
        background: #141414;
        display: grid;
        place-items: center;
      }
      .pt-logo {
        width: 56px;
        height: auto;
        opacity: 0;
      }
    </style>

    <script>
      import { initPage, syncScroll, coverPage, revealPage } from '../lib/motion';

      // Drive the GSAP curtain: cover the screen (in parallel with fetching the
      // next page) before the swap, then reveal it once the new page is in.
      document.addEventListener('astro:before-preparation', (e: any) => {
        const load = e.loader;
        e.loader = async () => {
          await Promise.all([coverPage(), load()]);
        };
      });

      // Don't re-navigate (and re-animate) when a link points at the page we're
      // already on. Capture-phase so it beats ClientRouter's own handler.
      document.addEventListener(
        'click',
        (e) => {
          const a = (e.target as HTMLElement)?.closest?.('a[href]') as HTMLAnchorElement | null;
          if (!a || a.target === '_blank' || a.hasAttribute('download')) return;
          const url = new URL(a.href, location.href);
          if (
            url.origin === location.origin &&
            url.pathname === location.pathname &&
            url.search === location.search &&
            url.hash === location.hash
          ) {
            e.preventDefault();
          }
        },
        { capture: true }
      );

      // Keep Lenis in sync with the scroll position ClientRouter set (top for a
      // new page, restored offset on history back/forward).
      document.addEventListener('astro:after-swap', syncScroll);
      // Runs on first load AND after every ClientRouter navigation.
      document.addEventListener('astro:page-load', () => {
        initPage();
        revealPage();
        // ponytail: manual GA page_view — ClientRouter nav doesn't reload the page
        if (typeof (window as any).gtag === 'function') {
          (window as any).gtag('event', 'page_view', {
            page_path: location.pathname + location.search,
            page_title: document.title,
          });
        }
      });
    </script>
  </body>
</html>
